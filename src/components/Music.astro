---

<section class="w-full min-h-screen bg-[#0a0a0a] pt-28 pb-20 px-4 md:px-8">

  <!-- Hero -->
  <div class="max-w-6xl mx-auto mb-14">
    <p class="text-[#00F5D4] text-xs font-black uppercase tracking-[0.35em] mb-4">FIFA World Cup 2026™ — Album Oficial</p>
    <h1 class="text-6xl md:text-8xl font-black uppercase text-white leading-none tracking-tighter mb-5">
      La Banda<br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00F5D4] via-[#8A2BE2] to-[#FF007F]">Sonora</span>
    </h1>
    <p class="text-white/40 text-sm max-w-lg leading-relaxed">
      18 tracks. Artistas de todo el mundo. Un solo sonido para el torneo mas grande de la historia.
    </p>
  </div>

  <!-- Grid de cards -->
  <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-5">
    {songs.map((song, index) => (
      <div
        class="player-card relative rounded-2xl overflow-hidden bg-[#1c1c1e] border border-white/8 group select-none"
        data-index={index}
      >
        <!-- Top bar: chevron + badge + dots -->
        <div class="flex items-center justify-between px-4 pt-4 pb-2">
          <svg class="w-4 h-4 text-white/30" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
          {song.featured && (
            <span
              class="text-[9px] font-black tracking-[0.15em] uppercase px-2 py-0.5 rounded-full border"
              style={`color:${song.accent}; border-color:${song.accent}50; background:${song.accent}18`}
            >
              {song.badge}
            </span>
          )}
          <div class="flex gap-[3px] items-center opacity-30">
            <span class="w-1 h-1 rounded-full bg-white block"></span>
            <span class="w-1 h-1 rounded-full bg-white block"></span>
            <span class="w-1 h-1 rounded-full bg-white block"></span>
          </div>
        </div>

        <!-- Cover art -->
        <div class="mx-4 rounded-xl overflow-hidden aspect-square bg-[#2a2a2e] relative">
          <img
            src={song.cover}
            alt={song.title}
            class="w-full h-full object-cover"
            loading="lazy"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <!-- Fallback si la imagen no carga -->
          <div class="absolute inset-0 flex-col items-center justify-center gap-3" style="display:none">
            <svg class="w-12 h-12 text-white/20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
            </svg>
            <span class="text-white/20 text-[10px] font-bold uppercase tracking-wider text-center px-2">{song.title}</span>
          </div>

          <!-- Track number (non-featured) -->
          {!song.featured && (
            <div class="absolute top-2 left-2 w-6 h-6 rounded-full bg-black/60 backdrop-blur-sm flex items-center justify-center">
              <span class="text-[9px] font-black text-white/60">{song.track}</span>
            </div>
          )}


        </div>

        <!-- Info: titulo + corazon -->
        <div class="px-4 pt-4 pb-1 flex items-start justify-between gap-2">
          <div class="min-w-0">
            <h3 class="text-white font-black text-[15px] leading-tight truncate">{song.title}</h3>
            <p class="text-white/40 text-[11px] mt-0.5 truncate">{song.type}</p>
          </div>
          <button class="heart-btn flex-shrink-0 mt-0.5 transition-all hover:scale-110 active:scale-95 opacity-60 hover:opacity-100" data-index={index}>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" style={`color:${song.accent}`}>
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
          </button>
        </div>

        <!-- Barra de progreso -->
        <div class="px-4 pb-1">
          <div
            class="progress-bar relative w-full h-[3px] bg-white/10 rounded-full overflow-hidden cursor-pointer"
            data-index={index}
          >
            <div
              class="progress-fill h-full rounded-full"
              style={`width:0%; background:${song.accent}`}
            ></div>
          </div>
          <div class="flex justify-between mt-1">
            <span class="elapsed-time text-[9px] text-white/25 font-mono tabular-nums">0:00</span>
            <span class="text-[9px] text-white/25 font-mono tabular-nums">3:27</span>
          </div>
        </div>

        <!-- Controles -->
        <div class="flex items-center justify-between px-4 pb-4 pt-1">
          <!-- Shuffle -->
          <button class="text-white/25 hover:text-white/60 transition-colors">
            <svg class="w-[15px] h-[15px]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41l-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"/>
            </svg>
          </button>

          <!-- Anterior -->
          <button class="prev-btn text-white/50 hover:text-white/90 transition-colors" data-index={index}>
            <svg class="w-[22px] h-[22px]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/>
            </svg>
          </button>

          <!-- Play / Pause -->
          <button
            class="play-btn w-11 h-11 rounded-full bg-white flex items-center justify-center shadow-md hover:scale-105 active:scale-95 transition-transform flex-shrink-0"
            data-index={index}
            data-url={song.youtubeUrl}
          >
            <svg class="play-icon w-[18px] h-[18px] text-[#1c1c1e] translate-x-0.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg class="pause-icon w-[18px] h-[18px] text-[#1c1c1e] hidden" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
            </svg>
          </button>

          <!-- Siguiente -->
          <button class="next-btn text-white/50 hover:text-white/90 transition-colors" data-index={index}>
            <svg class="w-[22px] h-[22px]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/>
            </svg>
          </button>

          <!-- Repeat -->
          <button class="text-white/25 hover:text-white/60 transition-colors">
            <svg class="w-[15px] h-[15px]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/>
            </svg>
          </button>
        </div>

      </div>
    ))}
  </div>

  <!-- Footer -->
  <p class="text-center text-white/15 text-[11px] mt-14 uppercase tracking-widest max-w-6xl mx-auto">
    &copy; FIFA Sound &middot; Def Jam Recordings &middot; SALXCO UAM &middot; Universal Music
  </p>

</section>

<script>
  interface PlayerState {
    playing: boolean;
    progress: number;
    interval: ReturnType<typeof setInterval> | null;
  }

  const cards = document.querySelectorAll<HTMLElement>('.player-card');
  const playerStates: PlayerState[] = Array.from(cards).map(() => ({
    playing: false,
    progress: 0,
    interval: null,
  }));

  function stopCard(i: number) {
    const state = playerStates[i];
    if (state.interval) { clearInterval(state.interval); state.interval = null; }
    state.playing = false;
    const card = cards[i];
    card.querySelector<SVGElement>('.play-icon')?.classList.remove('hidden');
    card.querySelector<SVGElement>('.pause-icon')?.classList.add('hidden');
  }

  function playCard(i: number) {
    playerStates.forEach((_, idx) => { if (idx !== i) stopCard(idx); });
    const state = playerStates[i];
    state.playing = true;
    const card = cards[i];
    card.querySelector<SVGElement>('.play-icon')?.classList.add('hidden');
    card.querySelector<SVGElement>('.pause-icon')?.classList.remove('hidden');
    const fill = card.querySelector<HTMLElement>('.progress-fill');
    const elapsed = card.querySelector<HTMLElement>('.elapsed-time');
    const totalSeconds = 207;
    state.interval = setInterval(() => {
      state.progress += 100 / totalSeconds;
      if (state.progress >= 100) { state.progress = 0; stopCard(i); return; }
      if (fill) fill.style.width = `${state.progress}%`;
      if (elapsed) {
        const s = Math.floor((state.progress / 100) * totalSeconds);
        elapsed.textContent = `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
      }
    }, 1000);
  }

  document.querySelectorAll<HTMLButtonElement>('.play-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const i = parseInt(btn.dataset.index ?? '0');
      if (playerStates[i].playing) { stopCard(i); }
      else {
        playCard(i);
        setTimeout(() => window.open(btn.dataset.url, '_blank', 'noopener,noreferrer'), 300);
      }
    });
  });

  document.querySelectorAll<HTMLElement>('.progress-bar').forEach(bar => {
    bar.addEventListener('click', (e) => {
      const i = parseInt(bar.dataset.index ?? '0');
      const rect = bar.getBoundingClientRect();
      const pct = Math.max(0, Math.min(100, ((e.clientX - rect.left) / rect.width) * 100));
      playerStates[i].progress = pct;
      const fill = bar.querySelector<HTMLElement>('.progress-fill');
      if (fill) fill.style.width = `${pct}%`;
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.heart-btn').forEach(btn => {
    btn.addEventListener('click', () => btn.classList.toggle('opacity-40'));
  });

  document.querySelectorAll<HTMLButtonElement>('.prev-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const i = parseInt(btn.dataset.index ?? '0');
      playerStates[i].progress = 0;
      const card = cards[i];
      const fill = card.querySelector<HTMLElement>('.progress-fill');
      const elapsed = card.querySelector<HTMLElement>('.elapsed-time');
      if (fill) fill.style.width = '0%';
      if (elapsed) elapsed.textContent = '0:00';
      if (playerStates[i].playing) { stopCard(i); playCard(i); }
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.next-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const i = parseInt(btn.dataset.index ?? '0');
      stopCard(i);
      playerStates[i].progress = 0;
      const card = cards[i];
      const fill = card.querySelector<HTMLElement>('.progress-fill');
      const elapsed = card.querySelector<HTMLElement>('.elapsed-time');
      if (fill) fill.style.width = '0%';
      if (elapsed) elapsed.textContent = '0:00';
    });
  });
</script>
