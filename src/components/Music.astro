const tracks = songs.filter(s => !s.featured);
---

<section class="w-full min-h-screen bg-[#0a0a0a] pt-28 pb-20 px-4 md:px-8">

  <!-- Hero -->
  <div class="max-w-6xl mx-auto mb-14">
    <p class="text-[#00F5D4] text-xs font-black uppercase tracking-[0.35em] mb-4">FIFA World Cup 2026™ — Álbum Oficial</p>
    <h1 class="text-6xl md:text-8xl font-black uppercase text-white leading-none tracking-tighter mb-5">
      La Banda<br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00F5D4] via-[#8A2BE2] to-[#FF007F]">Sonora</span>
    </h1>
    <p class="text-white/40 text-sm max-w-lg leading-relaxed">
      18 tracks. Artistas de todo el mundo. Un solo sonido para el torneo más grande de la historia.
    </p>
  </div>

  <!-- Featured cards: DNA + Dai Dai -->
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-4 mb-14">
    {featured.map(song => (
      <a
        href={song.youtubeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative rounded-2xl overflow-hidden bg-[#111111] border border-white/5 hover:border-white/20 transition-colors duration-300 cursor-pointer"
      >
        <!-- Cover art -->
        <div class={`relative w-full aspect-square bg-gradient-to-br ${song.gradient} flex items-center justify-center overflow-hidden`}>
          <!-- Decorative rings -->
          <div class="absolute inset-0 opacity-20 pointer-events-none">
            <div class="absolute top-4 left-4 w-32 h-32 rounded-full border-2 border-white/30"></div>
            <div class="absolute bottom-8 right-8 w-20 h-20 rounded-full border border-white/20"></div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-56 h-56 rounded-full border border-white/10"></div>
          </div>

          <!-- Badge -->
          <div class="absolute top-4 left-4 bg-black/50 backdrop-blur-sm rounded-lg px-3 py-1.5">
            <span class="text-[10px] font-black tracking-[0.2em] uppercase" style={`color: ${song.accentColor}`}>{song.badge}</span>
          </div>

          <!-- Flags top-right -->
          <div class="absolute top-4 right-4 flex gap-1.5">
            {[...new Set(song.flags)].map(flag => (
              <img
                src={`/flags/${flag}.svg`}
                alt={flag}
                class="w-7 h-5 object-cover rounded shadow-lg border border-white/20"
              />
            ))}
          </div>

          <!-- Play hover overlay -->
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/35 transition-colors duration-300 flex items-center justify-center">
            <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center translate-y-3 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 shadow-2xl">
              <svg class="w-7 h-7 text-black translate-x-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>

          <!-- Music note idle -->
          <svg class="w-20 h-20 text-white/20 group-hover:opacity-0 transition-opacity duration-300" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
          </svg>
        </div>

        <!-- Info -->
        <div class="p-5">
          <h3 class="text-white text-xl font-black uppercase tracking-tight leading-none mb-1">{song.title}</h3>
          <p class="text-white/50 text-sm">{song.artists}</p>
          <div class="flex items-center justify-between mt-4">
            <span class="text-white/25 text-xs">{song.release}</span>
            <div class="flex items-center gap-1.5 text-xs font-bold" style={`color: ${song.accentColor}`}>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              Ver en YouTube
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>

  <!-- Divider -->
  <div class="max-w-6xl mx-auto flex items-center gap-4 mb-8">
    <div class="h-px flex-1 bg-white/10"></div>
    <span class="text-white/30 text-[11px] font-black uppercase tracking-[0.3em]">Álbum — 18 Tracks</span>
    <div class="h-px flex-1 bg-white/10"></div>
  </div>

  <!-- Track grid -->
  <div class="max-w-6xl mx-auto grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
    {tracks.map(song => (
      <a
        href={song.youtubeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group bg-[#111111] hover:bg-[#1a1a1a] rounded-xl overflow-hidden border border-white/5 hover:border-white/15 transition-colors duration-200 cursor-pointer"
      >
        <!-- Cover -->
        <div class={`relative aspect-square bg-gradient-to-br ${song.gradient} overflow-hidden`}>
          <!-- Decorative circles -->
          <div class="absolute -top-4 -right-4 w-16 h-16 rounded-full bg-white/10 pointer-events-none"></div>
          <div class="absolute -bottom-3 -left-3 w-12 h-12 rounded-full bg-black/20 pointer-events-none"></div>

          <!-- Track number -->
          <div class="absolute top-2 left-2 w-6 h-6 rounded-full bg-black/50 flex items-center justify-center">
            <span class="text-[9px] font-black text-white/70">{song.track}</span>
          </div>

          <!-- Flags top-right -->
          <div class="absolute top-2 right-2 flex flex-col gap-1">
            {[...new Set(song.flags)].slice(0, 2).map(flag => (
              <img
                src={`/flags/${flag}.svg`}
                alt={flag}
                class="w-5 h-3.5 object-cover rounded shadow border border-white/20"
              />
            ))}
          </div>

          <!-- Play hover overlay -->
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors duration-200 flex items-center justify-center">
            <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center scale-75 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-200 shadow-xl">
              <svg class="w-5 h-5 text-black translate-x-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>

          <!-- Music note idle -->
          <div class="absolute inset-0 flex items-center justify-center group-hover:opacity-0 transition-opacity duration-200 pointer-events-none">
            <svg class="w-10 h-10 text-white/20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
            </svg>
          </div>
        </div>

        <!-- Info -->
        <div class="p-3">
          <p class="text-white text-xs font-bold leading-tight truncate">{song.title}</p>
          <p class="text-white/40 text-[10px] leading-tight mt-0.5 truncate">{song.artists}</p>
          <p class="text-white/20 text-[9px] mt-2 uppercase tracking-wider">{song.release}</p>
        </div>
      </a>
    ))}
  </div>

  <!-- Footer -->
  <p class="text-center text-white/15 text-[11px] mt-12 uppercase tracking-widest max-w-6xl mx-auto">
    © FIFA Sound · Def Jam Recordings · SALXCO UAM · Universal Music
  </p>

</section>
