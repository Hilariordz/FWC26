<header class="nav-oficial fixed top-0 left-0 w-full z-50 bg-[#2D107A] border-b border-white/10 h-20 flex items-center opacity-0 transform -translate-y-2">
  <div class="w-full max-w-[1440px] mx-auto px-4 md:px-8 flex items-center justify-between relative h-full">
    
    <div class="flex items-center gap-6 h-full relative">
      
      <div class="absolute top-0 left-0 bg-[#2D107A] pt-4 px-3 pb-3 rounded-b-[20px] shadow-[0_12px_24px_rgba(0,0,0,0.4)] flex flex-col items-center justify-start w-24 md:w-28 z-50">
        <a href="/" class="block w-full group">
          <img 
            src="/images/logo.png" 
            alt="Logo FIFA Monterrey 2026" 
            class="w-full h-auto transform group-hover:scale-102 transition-transform duration-300"
            loading="eager"
          />
        </a>
      </div>

      <div class="w-24 md:w-28 h-full"></div>

      <div class="flex items-center gap-1.5 text-xs font-bold tracking-wider text-white">
        <button class="hover:text-slate-300 transition-colors uppercase">En</button>
        <span class="text-white/40">|</span>
        <button class="text-[#00F5D4] uppercase">Es</button>
      </div>
    </div>

    <nav class="hidden lg:flex items-center gap-6 text-sm font-black text-white/80">
      <a href="/sedes" class="hover:text-white transition-colors uppercase tracking-tight">Sedes / Ciudades</a>
      <a href="/grupos" class="hover:text-white transition-colors uppercase tracking-tight">Grupos</a>
      <a href="/partidos" class="hover:text-white transition-colors uppercase tracking-tight">Calendario / Partidos</a>
      <a href="/musica" class="hover:text-white transition-colors uppercase tracking-tight">Música</a>
      <a href="/jugadores" class="hover:text-white transition-colors uppercase tracking-tight">Ultima Jugada</a>
    </nav>

    <div class="flex items-center gap-4 md:gap-6">
      <!-- z-[70] para que quede siempre encima del overlay del menú -->
      <button
        id="menu-toggle"
        class="lg:hidden text-white focus:outline-none p-1 flex flex-col gap-1.5 justify-center items-center w-8 h-8 relative z-[70]"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span class="line-1 w-6 h-0.5 bg-white rounded transition-transform duration-300 origin-center"></span>
        <span class="line-2 w-6 h-0.5 bg-white rounded transition-opacity duration-300"></span>
        <span class="line-3 w-6 h-0.5 bg-white rounded transition-transform duration-300 origin-center"></span>
      </button>
    </div>

  </div>
</header>

<!-- Overlay del menú fuera del header para evitar conflictos de z-index -->
<div
  id="full-menu"
  class="fixed inset-0 bg-[#2D107A]/98 backdrop-blur-md z-[60] flex flex-col justify-center items-center gap-6 text-2xl md:text-3xl font-black text-white/80 pointer-events-none opacity-0"
  aria-hidden="true"
>
  <a href="/sedes"       class="menu-item hover:text-white transition-colors uppercase tracking-tight">Sedes / Ciudades</a>
  <a href="/grupos"      class="menu-item hover:text-white transition-colors uppercase tracking-tight">Grupos</a>
  <a href="/partidos"    class="menu-item hover:text-white transition-colors uppercase tracking-tight">Calendario / Partidos</a>
  <a href="/musica"      class="menu-item hover:text-white transition-colors uppercase tracking-tight">Música</a>
  <a href="/jugadores"   class="menu-item hover:text-white transition-colors uppercase tracking-tight">Ultima Jugada</a>
</div>

<script>
  import { gsap } from 'gsap';

  // Animación de entrada del navbar
  gsap.to('.nav-oficial', {
    opacity: 1,
    y: 0,
    duration: 0.6,
    ease: 'power2.out'
  });

  const menuToggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
  const fullMenu   = document.getElementById('full-menu') as HTMLElement | null;
  const line1      = document.querySelector<HTMLElement>('.line-1');
  const line2      = document.querySelector<HTMLElement>('.line-2');
  const line3      = document.querySelector<HTMLElement>('.line-3');

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    menuToggle?.setAttribute('aria-expanded', 'true');
    fullMenu?.setAttribute('aria-hidden', 'false');
    fullMenu?.classList.remove('pointer-events-none');

    gsap.to(line1, { rotation: 45,  y:  7, duration: 0.25 });
    gsap.to(line2, { opacity: 0,        duration: 0.15 });
    gsap.to(line3, { rotation: -45, y: -7, duration: 0.25 });

    gsap.to(fullMenu, { opacity: 1, duration: 0.35, ease: 'power2.out' });
    gsap.fromTo(
      '.menu-item',
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.4, stagger: 0.08, ease: 'power3.out', delay: 0.1 }
    );
  }

  function closeMenu() {
    isOpen = false;
    menuToggle?.setAttribute('aria-expanded', 'false');
    fullMenu?.setAttribute('aria-hidden', 'true');

    gsap.to(line1, { rotation: 0, y: 0, duration: 0.25 });
    gsap.to(line2, { opacity: 1,        duration: 0.15 });
    gsap.to(line3, { rotation: 0, y: 0, duration: 0.25 });

    gsap.to(fullMenu, {
      opacity: 0,
      duration: 0.3,
      ease: 'power2.in',
      onComplete: () => fullMenu?.classList.add('pointer-events-none')
    });
  }

  menuToggle?.addEventListener('click', () => {
    isOpen ? closeMenu() : openMenu();
  });

  // Cerrar al hacer click en un enlace del menú
  document.querySelectorAll('.menu-item').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Cerrar con la tecla Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });
</script>
