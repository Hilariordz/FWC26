---
const players = [
  { name: "Lionel Messi",        country: "Argentina",      img: "/images/messi.webp",       flag: "ar" },
  { name: "Cristiano Ronaldo",   country: "Portugal",       img: "/images/cr.webp",          flag: "pt" },
  { name: "Luka Modrić",         country: "Croacia",        img: "/images/modric.webp",      flag: "hr" },
  { name: "Robert Lewandowski",  country: "Polonia",        img: "/images/lewandowski.webp", flag: "pl" },
  { name: "Kevin De Bruyne",     country: "Bélgica",        img: "/images/debruyne.webp",    flag: "be" },
  { name: "Neymar Jr",           country: "Brasil",         img: "/images/neymar.webp",      flag: "br" },
  { name: "Guillermo Ochoa",     country: "México",         img: "/images/ochoa.webp",       flag: "mx" },
  { name: "Luis Suárez",         country: "Uruguay",        img: "/images/suarez.webp",      flag: "uy" },
  { name: "Manuel Neuer",        country: "Alemania",       img: "/images/neuer.webp",       flag: "de" },
  { name: "Olivier Giroud",      country: "Francia",        img: "/images/giroud.webp",      flag: "fr" },
  { name: "Keylor Navas",        country: "Costa Rica",     img: "/images/navas.webp",       flag: "cr" },
  { name: "Antoine Griezmann",   country: "Francia",        img: "/images/griezmann.webp",   flag: "fr" },
  { name: "Heung-min Son",       country: "Corea del Sur",  img: "/images/son.webp",         flag: "kr" },
  { name: "Mohamed Salah",       country: "Egipto",         img: "/images/salah.webp",       flag: "eg" },
  { name: "Virgil van Dijk",     country: "Países Bajos",   img: "/images/vandijk.webp",     flag: "nl" },
  { name: "Sadio Mané",          country: "Senegal",        img: "/images/mane.webp",        flag: "sn" },
  { name: "James Rodríguez",     country: "Colombia",       img: "/images/james.webp",       flag: "co" },
  { name: "Thibaut Courtois",    country: "Bélgica",        img: "/images/courtois.webp",    flag: "be" },
  { name: "Casemiro",            country: "Brasil",         img: "/images/casemiro.webp",    flag: "br" },
  { name: "N'Golo Kanté",        country: "Francia",        img: "/images/kante.webp",       flag: "fr" },
];
---

<section class="relative bg-[#020617] text-white w-full py-32 overflow-hidden font-sans antialiased">
  
  <div class="absolute inset-0 pointer-events-none z-0">
    <div class="absolute top-0 left-1/4 w-[700px] h-[700px] bg-[#D4AF37]/[0.04] rounded-full blur-[140px]"></div>
    <div class="absolute bottom-0 right-1/4 w-[600px] h-[600px] bg-white/[0.02] rounded-full blur-[120px]"></div>
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 49px, white 49px, white 50px)"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 z-10">

    <div id="hero-header" class="flex flex-col items-center text-center mb-24">
      <h2 class="text-6xl md:text-9xl font-black uppercase leading-none tracking-tighter mb-6 select-none">
        <span class="block text-white/90">El Último</span>
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-white via-white/70 to-white drop-shadow-[0_10px_30px_rgba(255,255,255,0.08)]">
          Baile
        </span>
      </h2>

      <div class="flex items-center gap-4 mb-8 bg-white/[0.02] border border-white/5 px-6 py-2 rounded-full backdrop-blur-md">
        <span class="text-4xl font-black text-white/80 leading-none tabular-nums">{players.length}</span>
        <div class="w-px h-6 bg-white/10"></div>
        <div class="text-left">
          <p class="text-[10px] font-bold tracking-widest uppercase text-white/70">Leyendas Inmortales</p>
          <p class="text-[9px] text-white/40 uppercase tracking-wider">Copa del Mundo 2026</p>
        </div>
      </div>

      <p class="text-white/50 text-sm md:text-base font-light max-w-xl leading-relaxed balance">
        Homenaje a los gigantes del fútbol que disputarán sus últimos noventa minutos en el escenario más grande del planeta.
      </p>
    </div>

    <div id="grid-players" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-8">
      {players.map((player) => (
        <div 
          class="player-card relative bg-white/[0.03] border border-white/[0.08] overflow-hidden rounded-2xl backdrop-blur-sm"
          style="aspect-ratio: 3/4; --accent: rgba(255,255,255,0.18);"
        >
          {/* Imagen estática, visible y a color directo (o puedes dejarle el grayscale quitando group-hover) */}
          <div class="absolute inset-0 z-10 overflow-hidden">
            <img
              src={player.img}
              alt={player.name}
              class="w-full h-full object-cover object-top brightness-90"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#040405] via-[#040405]/50 to-transparent"></div>
          </div>

          <div class="absolute top-4 right-4 z-20">
            <img
              src={`/flags/${player.flag}.svg`}
              alt={player.country}
              class="w-9 h-6 object-cover rounded shadow-[0_4px_12px_rgba(0,0,0,0.6)] border border-white/20"
            />
          </div>

          <div class="absolute bottom-0 left-0 right-0 z-20 p-5 md:p-6">
            <p class="text-[9px] font-black tracking-[0.3em] uppercase text-white/60 mb-1">
              {player.country}
            </p>
            <h3 class="text-lg md:text-xl font-black uppercase leading-tight tracking-tight text-white">
              {player.name}
            </h3>
          </div>
        </div>
      ))}
    </div>

    <div id="hero-footer" class="flex items-center justify-center gap-6 mt-24">
      <div class="h-px flex-1 max-w-xs bg-gradient-to-r from-transparent to-white/20"></div>
      <span class="text-[10px] font-black tracking-[0.4em] uppercase text-white/30 whitespace-nowrap">FIFA World Cup 2026</span>
      <div class="h-px flex-1 max-w-xs bg-gradient-to-l from-transparent to-white/20"></div>
    </div>

  </div>
</section>
