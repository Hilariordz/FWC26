const fasesNombres = fases.map(f => f.nombre);
---

<section class="partidos-section w-full min-h-screen bg-[#0a0a1a] text-white pt-28 pb-20">
  <div class="max-w-[900px] mx-auto px-4 md:px-6">

    <!-- Header -->
    <div class="mb-10">
      <p class="text-[#00F5D4] text-xs font-bold tracking-[0.2em] uppercase mb-2">Copa Mundial de la FIFA 2026™</p>
      <h1 class="text-3xl md:text-5xl font-black uppercase tracking-tight leading-none">Calendario <span class="text-[#00F5D4]">&</span> Resultados</h1>
      <p class="text-white/40 text-sm mt-3">Hora local · Todos los partidos</p>
    </div>

    <!-- Filtros de fase -->
    <div class="fase-tabs flex flex-wrap gap-2 mb-10 sticky top-20 z-30 py-3 bg-[#0a0a1a]/95 backdrop-blur-sm border-b border-white/10">
      {fasesNombres.map((nombre, i) => (
        <button
          data-fase={i}
          class={`fase-btn text-xs font-bold uppercase tracking-wider px-4 py-2 rounded-full border transition-all duration-200 ${i === 0 ? 'bg-[#00F5D4] text-[#0a0a1a] border-[#00F5D4]' : 'bg-transparent text-white/50 border-white/20 hover:border-white/60 hover:text-white'}`}
        >
          {nombre}
        </button>
      ))}
    </div>

    <!-- Bloques de fases -->
    {fases.map((fase, fi) => (
      <div data-fase-content={fi} class={fi === 0 ? '' : 'hidden'}>
        {fase.rondas.map((ronda) => (
          <div class="mb-10">
            <!-- Cabecera de fecha -->
            <div class="flex items-center gap-3 mb-4">
              <div class="w-1.5 h-6 bg-[#00F5D4] rounded-full"></div>
              <h2 class="text-sm font-black uppercase tracking-widest text-white/70">{ronda.fecha}</h2>
            </div>

            <!-- Tarjetas de partidos -->
            <div class="flex flex-col gap-3">
              {ronda.partidos.map((partido) => (
                <div class={`partido-card group relative overflow-hidden rounded-2xl border transition-all duration-300 cursor-pointer
                  ${partido.finalizado
                    ? 'bg-gradient-to-r from-[#1a1a3a] to-[#12122a] border-[#00F5D4]/30 hover:border-[#00F5D4]/60'
                    : 'bg-[#11112a] border-white/8 hover:border-white/20'}`}>
                  
                  <!-- Accent line top -->
                  <div class={`absolute top-0 left-0 right-0 h-px ${partido.finalizado ? 'bg-gradient-to-r from-[#00F5D4]/50 via-[#00F5D4]/20 to-transparent' : 'bg-gradient-to-r from-white/10 via-white/5 to-transparent'}`}></div>

                  <div class="px-5 py-4 flex items-center gap-4">

                    <!-- Hora / Estado -->
                    <div class="w-16 flex-shrink-0 text-center">
                      {partido.finalizado ? (
                        <span class="inline-block text-[10px] font-black tracking-wider text-[#00F5D4] bg-[#00F5D4]/10 border border-[#00F5D4]/30 px-2 py-1 rounded-full uppercase">Final</span>
                      ) : (
                        <span class="text-white/60 text-sm font-bold tabular-nums">{partido.hora}</span>
                      )}
                    </div>

                    <!-- Equipo 1 -->
                    <div class="flex-1 flex items-center gap-3 justify-end">
                      <span class={`text-sm md:text-base font-black text-right leading-tight ${partido.finalizado ? 'text-white' : 'text-white/80'}`}>
                        {partido.equipo1}
                      </span>
                      {partido.bandera1 ? (
                        <img
                          src={`/flags/${partido.bandera1}.svg`}
                          alt={partido.equipo1}
                          class="w-8 h-6 object-cover rounded-sm flex-shrink-0 shadow-md"
                          loading="lazy"
                        />
                      ) : (
                        <div class="w-8 h-6 rounded-sm bg-white/10 flex items-center justify-center flex-shrink-0">
                          <span class="text-[8px] text-white/30 font-bold">TBD</span>
                        </div>
                      )}
                    </div>

                    <!-- Marcador o VS -->
                    <div class="w-20 flex-shrink-0 text-center">
                      {partido.finalizado ? (
                        <div class="flex items-center justify-center gap-2">
                          <span class="text-2xl font-black text-white tabular-nums">{partido.gol1}</span>
                          <span class="text-white/30 text-xs font-bold">-</span>
                          <span class="text-2xl font-black text-white tabular-nums">{partido.gol2}</span>
                        </div>
                      ) : (
                        <div class="flex flex-col items-center">
                          <span class="text-[10px] font-black tracking-widest text-white/20 uppercase">vs</span>
                        </div>
                      )}
                    </div>

                    <!-- Equipo 2 -->
                    <div class="flex-1 flex items-center gap-3">
                      {partido.bandera2 ? (
                        <img
                          src={`/flags/${partido.bandera2}.svg`}
                          alt={partido.equipo2}
                          class="w-8 h-6 object-cover rounded-sm flex-shrink-0 shadow-md"
                          loading="lazy"
                        />
                      ) : (
                        <div class="w-8 h-6 rounded-sm bg-white/10 flex items-center justify-center flex-shrink-0">
                          <span class="text-[8px] text-white/30 font-bold">TBD</span>
                        </div>
                      )}
                      <span class={`text-sm md:text-base font-black leading-tight ${partido.finalizado ? 'text-white' : 'text-white/80'}`}>
                        {partido.equipo2}
                      </span>
                    </div>

                    <!-- Info estadio (desktop) -->
                    <div class="hidden lg:flex flex-col items-end w-40 flex-shrink-0 gap-0.5">
                      <span class="text-[10px] font-bold text-[#00F5D4]/70 uppercase tracking-wider">{partido.grupo}</span>
                      <span class="text-[11px] text-white/40 text-right leading-tight">{partido.estadio}</span>
                      <span class="text-[10px] text-white/25">{partido.ciudad}</span>
                    </div>

                  </div>

                  <!-- Info estadio (mobile) -->
                  <div class="lg:hidden px-5 pb-3 flex items-center justify-between gap-2 border-t border-white/5 mt-0 pt-2">
                    <span class="text-[10px] font-bold text-[#00F5D4]/70 uppercase tracking-wider">{partido.grupo}</span>
                    <span class="text-[10px] text-white/35">{partido.estadio} · {partido.ciudad}</span>
                  </div>

                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    ))}

  </div>
</section>

<script>
  const faseBtns = document.querySelectorAll<HTMLButtonElement>('.fase-btn');
  const faseContents = document.querySelectorAll<HTMLElement>('[data-fase-content]');

  faseBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.fase;

      faseBtns.forEach(b => {
        b.classList.remove('bg-[#00F5D4]', 'text-[#0a0a1a]', 'border-[#00F5D4]');
        b.classList.add('bg-transparent', 'text-white/50', 'border-white/20');
      });
      btn.classList.add('bg-[#00F5D4]', 'text-[#0a0a1a]', 'border-[#00F5D4]');
      btn.classList.remove('bg-transparent', 'text-white/50', 'border-white/20');

      faseContents.forEach(c => {
        if (c.dataset.faseContent === target) {
          c.classList.remove('hidden');
        } else {
          c.classList.add('hidden');
        }
      });
    });
  });
</script>
