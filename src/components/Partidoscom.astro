  bandera2: string | null;
  gol2?: number;
  grupo: string;
  estadio: string;
  ciudad: string;
  finalizado: boolean;
}

interface Ronda {
  fecha: string;
  partidos: Partido[];
}

interface Fase {
  nombre: string;
  rondas: Ronda[];
}

